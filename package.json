{
  "name": "@lumirelle/tsconfig",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "bun@1.3.11",
  "description": "Lumirelle's opinionated TypeScript config",
  "author": "Lumirelle <shabbyacc@outlook.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/lumirelle",
  "homepage": "https://github.com/lumirelle/tsconfig#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lumirelle/tsconfig.git"
  },
  "bugs": "https://github.com/lumirelle/tsconfig/issues",
  "keywords": [],
  "exports": {
    "./lib": "./tsconfig.lib.json",
    "./vue": "./tsconfig.vue.json",
    "./package.json": "./package.json"
  },
  "files": [
    "internal",
    "tsconfig.lib.json",
    "tsconfig.vue.json"
  ],
  "workspaces": {
    "packages": [],
    "catalogs": {
      "dev": {
        "bumpp": "^11.0.1",
        "simple-git-hooks": "git+https://github.com/toplenboren/simple-git-hooks.git#7625657",
        "typescript": "^5.9.3",
        "vue": "^3.5.30"
      },
      "types": {
        "@types/bun": "^1.3.11"
      },
      "check": {
        "@antfu/eslint-config": "^7.7.3",
        "@arethetypeswrong/cli": "^0.18.2",
        "@lumirelle/oxlint-config": "^0.0.5",
        "eslint": "^10.0.3",
        "eslint-plugin-oxlint": "^1.56.0",
        "knip": "^6.0.0",
        "nano-staged": "^0.9.0",
        "oxlint": "^1.56.0",
        "oxlint-tsgolint": "0.17.0",
        "publint": "^0.3.18"
      },
      "test": {
        "vitest-package-exports": "^1.2.0"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "start": "bun run ./src/index.ts",
    "lint": "bun run --parallel oxlint eslint",
    "lint:fix": "oxlint --fix && eslint --fix",
    "unused": "knip-bun",
    "pubcheck": "bun run --parallel 'attw --pack --profile esm-only' publint",
    "gitcheck": "bun run ./scripts/check-git-status.sh",
    "check": "bun run --parallel lint unused pubcheck gitcheck",
    "test": "bun test",
    "prerelease": "bun run --parallel check test",
    "release": "bumpp"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:check",
    "@arethetypeswrong/cli": "catalog:check",
    "@lumirelle/oxlint-config": "catalog:check",
    "@lumirelle/tsconfig": "file:.",
    "@types/bun": "catalog:types",
    "bumpp": "catalog:dev",
    "eslint": "catalog:check",
    "eslint-plugin-oxlint": "catalog:check",
    "knip": "catalog:check",
    "nano-staged": "catalog:check",
    "oxlint": "catalog:check",
    "oxlint-tsgolint": "catalog:check",
    "publint": "catalog:check",
    "simple-git-hooks": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest-package-exports": "catalog:test",
    "vue": "catalog:dev"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx nano-staged"
  },
  "nano-staged": {
    "*": [
      "oxlint",
      "eslint"
    ]
  }
}
